<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <h2>Dashboard</h2>
        <div class="dashboard-card">
            <p><strong>Name:</strong>
                <%= name %>
            </p>
            <p><strong>Username:</strong>
                <%= email %>
            </p>
        </div>

        <% if (user && user.role_name==='admin' ) { %>
            <p><a class="btn" href="/users">View All Users</a></p>
        <% } %>
    </main>

<%- include('partials/footer') %>