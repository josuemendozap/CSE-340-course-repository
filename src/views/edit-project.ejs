<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <% const formattedDate=new Date(projectDetails.date).toISOString().split('T')[0]; %>

            <form action="/edit-project/<%= projectDetails.project_id %>" method="POST">

                <div class="form-group">
                    <label for="title">Service Project Title</label>
                    <input type="text" id="title" name="title" required maxlength="250"
                        value="<%= projectDetails.title %>" />
                </div>

                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea id="description" name="description" required
                        maxlength="500"><%= projectDetails.description %></textarea>
                </div>

                <div class="form-group">
                    <label for="location">Location</label>
                    <input type="text" id="location" name="location" required value="<%= projectDetails.location %>" />
                </div>

                <div class="form-group">
                    <label for="date">Date</label>
                    <input type="date" id="date" name="date" required value="<%= formattedDate %>" />
                </div>

                <div class="form-group">
                    <label for="organizationId">Organization</label>
                    <select name="organizationId" id="organizationId" required>
                        <option value="">Select an Organization</option>

                        <% organizations.forEach(org=> { %>
                            <option value="<%= org.organization_id %>"
                                <%= org.organization_id === projectDetails.organization_id ? 'selected' : '' %>>
                                <%= org.name %>
                            </option>
                            <% }); %>
                    </select>
                </div>

                <button type="submit" class="btn">Update Project</button>
            </form>
    </main>
<%- include('partials/footer') %>