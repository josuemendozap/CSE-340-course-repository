<%- include('partials/header') %>
<main>
    <h1>
        <%= title %>
    </h1>
    <ul>
        <% categories.forEach(category=> { %>
            <li>
                <a href="/category/<%= category.category_id %>"><%= category.name %></a>
            </li>
        <% }) %>
    </ul>
    
    <p><a class="btn" href="/new-category">Add a new Category</a></p>

</main>
<%- include('partials/footer') %>