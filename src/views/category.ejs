<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    
    <h2><%= categoryDetails.name %></h2>

    <ul>
        <% projectsByCategory.forEach(project => { %>
            <li>
                <a href="/project/<%= project.project_id %>"><%= project.title %></a>
            </li>
        <% }) %>
    </ul>

    <p><a class="btn" href="/edit-category/<%= categoryDetails.category_id %>">Edit Category</a></p>

</main>
<%- include('partials/footer') %>